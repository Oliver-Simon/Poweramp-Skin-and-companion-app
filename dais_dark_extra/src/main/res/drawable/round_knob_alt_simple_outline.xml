<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="?attr/colorIconPrimary"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item android:state_enabled="false">
                <layer-list>
                    <item>
                        <shape android:shape="oval">
                            <stroke android:width="1.5dip" android:color="#4affffff" />
                        </shape>
                    </item>
                </layer-list>
            </item>
            <item android:state_pressed="true">
                <layer-list>
                    <item>
                        <shape android:shape="oval">
                            <solid android:color="?attr/colorIconPrimary" />
                        </shape>
                    </item>
                </layer-list>
            </item>
            <item android:state_enabled="true">
                <layer-list>
                    <item>
                        <shape android:shape="oval">
                            <solid android:color="?attr/colorIconPrimary" />
                            <stroke android:width="1.5dip" android:color="?attr/colorIconPrimary" />
                        </shape>
                    </item>
                </layer-list>
            </item>
        </selector>
    </item>
</ripple>