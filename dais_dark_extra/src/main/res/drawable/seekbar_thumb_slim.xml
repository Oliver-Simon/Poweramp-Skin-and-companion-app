<?xml version="1.0" encoding="utf-8"?>
<animated-selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <solid android:color="?android:colorControlNormal" />
            <size android:height="13.0dip" android:width="13.0dip" />
        </shape>
    </item>
    <item android:state_pressed="true" android:id="@+id/outsideInset">
        <shape android:shape="oval">
            <solid android:color="?attr/colorIconPrimary" />
            <size android:height="13.0dip" android:width="13.0dip" />
        </shape>
    </item>
    <item android:id="@+id/title_container">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <size android:height="13.0dip" android:width="13.0dip" />
                    <solid android:color="#ffffffff" />
                </shape>
            </item>
        </layer-list>
    </item>
</animated-selector>