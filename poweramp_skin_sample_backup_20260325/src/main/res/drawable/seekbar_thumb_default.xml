<?xml version="1.0" encoding="utf-8"?>
<animated-selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <size android:height="5.0dip" />
            <solid android:color="?android:colorControlNormal" />
            <corners android:radius="25.0dip" />
        </shape>
    </item>
    <item android:state_pressed="true" android:id="@+id/outsideInset">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <size android:height="5.0dip" android:width="15.0dip" />
                    <solid android:color="?android:colorAccent" />
                    <corners android:radius="0.0dip" />
                    <padding android:right="-2.5dip" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <size android:height="5.0dip" android:width="15.0dip" />
                    <solid android:color="#ffffffff" />
                    <corners android:radius="25.0dip" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:id="@+id/title_container">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <size android:height="5.0dip" android:width="15.0dip" />
                    <solid android:color="?android:colorAccent" />
                    <corners android:radius="0.0dip" />
                    <padding android:right="-2.5dip" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <size android:height="5.0dip" android:width="15.0dip" />
                    <solid android:color="#ffffffff" />
                    <corners android:radius="25.0dip" />
                </shape>
            </item>
        </layer-list>
    </item>
</animated-selector>